[Unit]
Description=ClinikAuto Node App
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/clinikauto
Environment=NODE_ENV=production
EnvironmentFile=/etc/clinikauto.env
ExecStart=/usr/bin/node backend/server.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
