## ClinikAuto example env (DO NOT commit secrets)
# Copy this file to /etc/clinikauto.env or provide as env_file for docker-compose
PORT=3000
JWT_SECRET=change_me_secure
FRONTEND_ORIGIN=http://localhost:3000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# SMTP settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=changeme
SMTP_FROM=ClinikAuto <no-reply@example.com>

# Google Calendar (optional)
GOOGLE_CALENDAR_ICS_URL=
GOOGLE_CALENDAR_SYNC_ENABLED=false
